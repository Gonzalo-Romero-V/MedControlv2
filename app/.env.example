# AI Provider — valores posibles: gemini | openai
AI_PROVIDER=gemini

# API key del proveedor de IA (AI parsing de recetas)
# Gemini: obtener en aistudio.google.com
# OpenAI: obtener en platform.openai.com
AI_API_KEY=your_api_key_here

# Modelo específico (opcional — si no se define, cada implementación usa su default)
# Gemini: gemini-2.0-flash | gemini-2.5-flash
# OpenAI: gpt-4o | gpt-4o-mini
AI_MODEL=gemini-2.0-flash

# Path del asset con las credenciales de service account para Cloud Vision OCR (Ruta 1)
# Obtener en console.cloud.google.com → APIs & Services → Credentials → Service account
# Requiere que Cloud Vision API esté habilitada en el proyecto
# Agregar el archivo JSON a pubspec.yaml → flutter → assets
# Agregar a .gitignore para no subirlo al repositorio
# Si no está configurado, el sistema usa ML Kit on-device (Ruta 2 — fallback offline)
VISION_CREDENTIALS_PATH=your_service_account.json
