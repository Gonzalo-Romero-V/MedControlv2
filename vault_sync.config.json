{
  "schema_version": "1.0",
  "project_name": "MedControlv2",
  "vault_path": "C:/Users/Gonzalo/Dev/MATERIAS/02_BC/MedControlv2/vault",
  "extractor": "generic",
  "hierarchy_mapping": {
    "H1_intent": [
      "vault/intent/**"
