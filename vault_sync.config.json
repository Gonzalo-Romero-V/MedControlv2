      "package.json",
      "pyproject.toml",
      "Cargo.toml",
      "go.mod",
      "pom.xml",
      "build.gradle",
      "Gemfile",
      "composer.json",
      "angular.json",
      "Dockerfile",
      "docker-compose*.yml",
      ".gitignore",
      ".gitattributes"
    ],
    "H4_contracts": [
      "src/**/models/**",
      "src/**/types/**",
      "src/**/schemas/**",
      "src/**/entities/**",
      "internal/**/types/**",
      "internal/**/models/**",
      "app/**/models/**",
      "app/**/schemas/**",
      "**/*.proto",
      "migrations/**",
      "db/migrations/**"
    ],
    "H5_implementation": [
      "src/**/services/**",
      "src/**/controllers/**",
      "src/**/handlers/**",
      "src/**/components/**",
      "internal/**/handlers/**",
      "cmd/**",
      "app/**/services/**",
      "app/**/api/**"
    ],
    "ENV_references": [
      ".env",
      ".env.example",
      ".env.local",
      ".env.production"
    ]
  },
  "exclude_patterns": [
    "vault/INDEX.md",
    "vault/SYSTEM.md",
    "vault/.obsidian/**",
    "**/node_modules/**",
    "**/vendor/**",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/venv/**",
    "**/target/**",
    "**/build/**",
    "**/dist/**",
    "**/.next/**",
    "**/.gradle/**",
    "**/*.lock",
    "**/*-lock.json",
    "**/*.log",
    "**/graphify-out/**",
    "bootstrap/init_vault.py",
    "bootstrap/stacks/**",
    "bootstrap/vault-skeleton/**",
    "scripts/vault_sync.py",
    "scripts/lib/**",
    "hooks/post-commit",
    "CHANGELOG.md"
